; Engine configuration file.
; ET Office Desktop — wallpaper renderer (Godot 4.6)
config_version=5

[application]

config/name="ET Office Desktop"
config/description="Cyberpunk synthwave isometric AI agent office — live desktop wallpaper"
run/main_scene="res://scenes/office_floor.tscn"
config/features=PackedStringArray("4.6")

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/borderless=true
window/size/always_on_top=false

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
