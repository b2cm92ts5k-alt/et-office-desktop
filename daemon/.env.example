# ET Office Desktop — environment config
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่า — ไฟล์ .env จะไม่ถูก commit (อยู่ใน .gitignore)

# --- Daemon ---
ET_OFFICE_PORT=8797
ET_OFFICE_DB=daemon/data/etoffice.sqlite

# --- Local AI (default — ฟรี ไม่ต้องใส่ key) ---
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LOCAL_MODEL=qwen3:8b

# --- Cloud AI (optional — ใส่เฉพาะที่อยากใช้; ใส่ผ่าน UI Settings ก็ได้ เก็บเข้ารหัส DPAPI) ---
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=          # Grok (console.x.ai) — M14
DEEPSEEK_API_KEY=     # DeepSeek (platform.deepseek.com) — M14

# --- Web search (optional — M15) ---
# ไม่ใส่ = ใช้ DuckDuckGo ฟรี (keyless); ใส่ = ใช้ Brave Search API (แม่นกว่า)
BRAVE_API_KEY=

# --- GitHub (optional — M9; ให้ agent จัดการ issue/commit/push) ---
# ใส่ผ่าน UI Settings ได้ (validate + เก็บที่นี่); ใช้ fine-grained token scope แคบ
GITHUB_TOKEN=
